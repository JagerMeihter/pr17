<Window x:Class="pr17.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" 
        Height="880" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F"
        ResizeMode="NoResize">

    <Grid Margin="35">
        <StackPanel>
            <TextBlock Text="Оформление заказа" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,35"/>

            <TextBlock Text="Дата доставки (не позднее 7 дней)" 
                       Foreground="#2C3E50" 
                       FontSize="15"
                       Margin="0,0,0,10"/>

            <DatePicker x:Name="datePicker" 
                        Height="45" 
                        Background="#2C3E50"
                        Foreground="#2C3E50"
                        BorderBrush="#3498DB"
                        Margin="0,0,0,25"/>

            <TextBlock Text="Способ оплаты" 
                       Foreground="#2C3E50" 
                       FontSize="15"
                       Margin="0,0,0,10"/>

            <ComboBox x:Name="cmbPaymentMethod" 
                      Height="45" 
                      Background="#2C3E50"
                      Foreground="#2C3E50"
                      FontSize="15"
                      Margin="0,0,0,30">
                <ComboBoxItem Content="Наличные при получении" IsSelected="True"/>
                <ComboBoxItem Content="Банковская карта"/>
            </ComboBox>

            <!-- Итог -->
            <Border Background="#2C3E50" CornerRadius="10" Padding="20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Итого к оплате:" 
                               FontSize="17" 
                               Foreground="#BBBBBB"/>
                    <TextBlock x:Name="txtTotalAmount" 
                               Text="0 ₽" 
                               FontSize="21" 
                               FontWeight="Bold" 
                               Foreground="#2ECC71"
                               Margin="25,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,35,0,0">
                <Button Content="Отмена" 
                        Width="150" 
                        Height="50" 
                        Margin="10"
                        Background="#E74C3C" 
                        Foreground="White"
                        FontSize="15"
                        Click="BtnCancel_Click"/>

                <Button Content="Подтвердить заказ" 
                        Width="220" 
                        Height="50" 
                        Margin="10"
                        Background="#27AE60" 
                        Foreground="White"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>