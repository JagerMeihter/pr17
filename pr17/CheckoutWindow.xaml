<Window x:Class="pr17.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" 
        Height="420" 
        Width="460"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F"
        ResizeMode="NoResize">

    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="Оформление заказа" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,25"/>

            <!-- Выбор даты доставки -->
            <TextBlock Text="Выберите дату доставки (не позднее 7 дней)" 
                       Foreground="White" 
                       FontSize="14"
                       Margin="0,0,0,8"/>

            <DatePicker x:Name="datePicker" 
                        Height="35" 
                        Margin="0,0,0,20"
                        Background="#2C3E50"
                        Foreground="White"
                        SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            <!-- Способ оплаты -->
            <TextBlock Text="Способ оплаты" 
                       Foreground="White" 
                       FontSize="14"
                       Margin="0,10,0,8"/>

            <ComboBox x:Name="cmbPaymentMethod" 
                      Height="35" 
                      Margin="0,0,0,25"
                      Background="#2C3E50"
                      Foreground="White">
                <ComboBoxItem Content="Наличные при получении" IsSelected="True"/>
                <ComboBoxItem Content="Банковская карта"/>
            </ComboBox>

            <!-- Итоговая сумма -->
            <Border Background="#2C3E50" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Итого к оплате:" 
                               FontSize="16" 
                               Foreground="#AAAAAA"/>
                    <TextBlock x:Name="txtTotalAmount" 
                               Text="0 ₽" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="#2ECC71"
                               Margin="15,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Отмена" 
                        Width="140" 
                        Height="45" 
                        Margin="10"
                        Background="#E74C3C" 
                        Foreground="White"
                        Click="BtnCancel_Click"/>

                <Button Content="Подтвердить заказ" 
                        Width="180" 
                        Height="45" 
                        Margin="10"
                        Background="#27AE60" 
                        Foreground="White"
                        FontSize="15"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>