<Window x:Class="pr17.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Космическая ложа" 
        Height="720" 
        Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F">

    <Grid>
        <!-- Верхняя панель командования -->
        <Border Background="#2C3E50" Height="60" VerticalAlignment="Top">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="15,0">
                    <Button Content="← Назад" 
                            Width="90" 
                            Height="40" 
                            Margin="5"
                            Background="#34495E" 
                            Foreground="White" 
                            FontSize="14"
                            Click="BtnBack_Click"/>

                    <Button Content="Главная" 
                            Width="110" 
                            Height="40" 
                            Margin="5"
                            Background="#34495E" 
                            Foreground="White" 
                            Click="BtnHome_Click"/>

                    <Button Content="Магазин" 
                            Width="110" 
                            Height="40" 
                            Margin="5"
                            Background="#34495E" 
                            Foreground="White" 
                            Click="BtnProducts_Click"/>
                </StackPanel>

                <!-- Правая часть панели -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="15,0">

                    <Button x:Name="btnCart" 
                            Content="Корзина (0)" 
                            Width="130" 
                            Height="40" 
                            Margin="5"
                            Background="#E67E22" 
                            Foreground="White"
                            Visibility="Collapsed"
                            Click="BtnCart_Click"/>

                    <Button x:Name="btnAccount" 
                            Content="Мой кабинет" 
                            Width="130" 
                            Height="40" 
                            Margin="5"
                            Background="#3498DB" 
                            Foreground="White"
                            Visibility="Collapsed"
                            Click="BtnAccount_Click"/>

                    <Button Content="Выход" 
                            Width="90" 
                            Height="40" 
                            Margin="5"
                            Background="#E74C3C" 
                            Foreground="White"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область навигации -->
        <Frame x:Name="MainFrame" 
               Margin="0,60,0,0" 
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>