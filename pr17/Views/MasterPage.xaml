<Page x:Class="pr17.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель мастера"
      Background="#1E1E2F">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Панель мастера" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#3498DB"/>

            <TextBlock x:Name="txtMasterName" 
                       FontSize="18" 
                       Foreground="#AAAAAA"
                       Margin="30,8,0,0"/>
        </StackPanel>

        <!-- Список записей на мастера -->
        <ListView x:Name="lvMyAppointments" 
                  Grid.Row="1"
                  Background="Transparent" 
                  BorderBrush="#34495E"
                  Foreground="White">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2C3E50" 
                            CornerRadius="8" 
                            Padding="15" 
                            Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding Client.FullName}" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding ServiceType.Name}" 
                                           FontSize="15"
                                           Foreground="#3498DB"/>
                                <TextBlock Text="{Binding DateTime, StringFormat='dd.MM.yyyy в HH:mm'}" 
                                           Foreground="#AAAAAA"/>
                                <TextBlock Text="{Binding Comment}" 
                                           Foreground="#777777"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"/>
                            </StackPanel>

                            <Button Content="Завершить услугу" 
                                    Grid.Column="1"
                                    Width="160"
                                    Height="40"
                                    Background="#27AE60"
                                    Foreground="White"
                                    VerticalAlignment="Center"
                                    Click="BtnComplete_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>