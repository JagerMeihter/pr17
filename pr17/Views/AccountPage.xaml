<Page x:Class="pr17.AccountPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет"
      Background="#1E1E2F">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и информация о пользователе -->
        <StackPanel>
            <TextBlock Text="Личный кабинет" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <Border Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock x:Name="txtFullName"
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock x:Name="txtPhone"
                               FontSize="14" 
                               Foreground="#AAAAAA"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
        <!-- Кнопка записи к мастеру -->
        <Button Content="Записаться к мастеру" 
                Height="55" 
                Width="320" 
                Margin="0,0,0,25"
                Background="#3498DB" 
                Foreground="White"
                FontSize="17"
                FontWeight="SemiBold"
                Click="BtnBookAppointment_Click"/>
        <!-- Вкладки -->
        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="#34495E">
            <Button Content="Записаться к мастеру" 
                Height="50" 
                Width="280" 
                Margin="0,0,0,20"
                Background="#3498DB" 
                Foreground="White"
                FontSize="16"
                FontWeight="SemiBold"
                Click="BtnBookAppointment_Click"/>  
            <!-- Мои записи -->
            <TabItem Header="Мои записи">
                <ListView x:Name="lvAppointments" 
                          Background="Transparent" 
                          BorderBrush="#34495E"
                          Foreground="White"
                          Margin="5">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2C3E50" CornerRadius="6" Padding="12" Margin="3">
                                <StackPanel>
                                    <TextBlock Text="{Binding ServiceType.Name}" 
                                               FontWeight="Bold" 
                                               FontSize="15"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding Master.FullName}" 
                                               Foreground="#3498DB"/>
                                    <TextBlock Text="{Binding DateTime, StringFormat='dd.MM.yyyy HH:mm'}" 
                                               Foreground="#AAAAAA"/>
                                    <TextBlock Text="{Binding Status}" 
                                               Foreground="#2ECC71"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabItem>

            <!-- Мои заказы -->
            <TabItem Header="Мои заказы">
                <ListView x:Name="lvOrders" 
                          Background="Transparent" 
                          BorderBrush="#34495E"
                          Foreground="White"
                          Margin="5">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2C3E50" CornerRadius="6" Padding="12" Margin="3">
                                <StackPanel>
                                    <TextBlock Text="{Binding OrderDate, StringFormat='Заказ от dd.MM.yyyy'}" 
                                               FontWeight="Bold"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding DeliveryDate, StringFormat='Доставка: dd.MM.yyyy'}" 
                                               Foreground="#AAAAAA"/>
                                    <TextBlock Text="Статус: Доставлен" 
                                               Foreground="#2ECC71"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabItem>
        </TabControl>
    </Grid>
</Page>