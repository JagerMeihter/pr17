<Window x:Class="pr17.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" 
        Height="320" 
        Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Космическая ложа" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Логин" Foreground="White" FontSize="14" Margin="0,5"/>
            <TextBox x:Name="txtLogin" 
                     Height="35" 
                     Background="#2C3E50" 
                     Foreground="White" 
                     BorderBrush="#3498DB"/>

            <TextBlock Text="Пароль" Foreground="White" FontSize="14" Margin="0,15,0,5"/>
            <PasswordBox x:Name="txtPassword" 
                         Height="35" 
                         Background="#2C3E50" 
                         Foreground="White" 
                         BorderBrush="#3498DB"/>

            <Button Content="Войти" 
                    Height="45" 
                    Margin="0,30,0,10" 
                    Background="#27AE60" 
                    Foreground="White" 
                    FontSize="16"
                    Click="BtnLogin_Click"/>

            <Button Content="Отмена" 
                    Height="35" 
                    Background="#E74C3C" 
                    Foreground="White"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>