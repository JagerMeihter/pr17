<Window x:Class="pr17.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" 
        Height="380" 
        Width="460"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F"
        ResizeMode="NoResize"
        BorderThickness="1"
        BorderBrush="#3498DB">

    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">

            <!-- Заголовок -->
            <TextBlock Text="КОСМИЧЕСКАЯ ЛОЖА" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Логин -->
            <TextBlock Text="Логин" 
                       Foreground="#CCCCCC" 
                       FontSize="14" 
                       Margin="0,0,0,8"/>

            <TextBox x:Name="txtLogin" 
                     Height="42" 
                     Background="#2C3E50" 
                     Foreground="White" 
                     BorderBrush="#3498DB"
                     BorderThickness="2"
                     FontSize="15"
                     Padding="10,0"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,20"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль" 
                       Foreground="#CCCCCC" 
                       FontSize="14" 
                       Margin="0,0,0,8"/>

            <PasswordBox x:Name="txtPassword" 
                         Height="42" 
                         Background="#2C3E50" 
                         Foreground="White" 
                         BorderBrush="#3498DB"
                         BorderThickness="2"
                         FontSize="15"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,30"/>

            <!-- Кнопки -->
            <Button Content="Войти" 
                    Height="48" 
                    Background="#27AE60" 
                    Foreground="White"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Click="BtnLogin_Click"
                    Margin="0,0,0,12"/>
            <Button Content="Регистрация" 
                    Height="40" 
                    Margin="0,10,0,0"
                    Background="#3498DB" 
                    Foreground="White"
                    Click="BtnRegister_Click"/>
            <Button Content="Регистрация нового клиента" 
                    Height="40" 
                    Margin="0,12,0,0"
                    Background="#3498DB" 
                    Foreground="White"
                    FontSize="14"
                    Click="BtnRegister_Click"/>
            <Button Content="Отмена" 
                    Height="40" 
                    Background="#E74C3C" 
                    Foreground="White"
                    FontSize="15"
                    Click="BtnCancel_Click"/>

        </StackPanel>
    </Grid>
</Window>