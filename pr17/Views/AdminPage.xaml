<Page x:Class="pr17.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:pr17.Converters"
      Title="Панель администратора"
      Background="#1E1E2F">

    <Page.Resources>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </Page.Resources>
    
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,25">
            <TextBlock Text="Панель администратора" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#E74C3C" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Управление всеми пользователями системы" 
                       FontSize="15" 
                       Foreground="#AAAAAA" 
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <ListView x:Name="lvUsers" 
                  Grid.Row="1"
                  Background="Transparent" 
                  BorderBrush="#34495E"
                  Foreground="White"
                  Margin="5">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2C3E50" 
                            CornerRadius="10" 
                            Padding="16" 
                            Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" 
                                           FontSize="17" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding Login}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="{Binding Phone}" 
                                           Foreground="#AAAAAA"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Role}" 
                                       FontSize="15"
                                       VerticalAlignment="Center"
                                       Margin="40,0"
                                       Foreground="#F1C40F"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Изменить роль" 
                                        Width="130" 
                                        Height="38" 
                                        Margin="5"
                                        Background="#3498DB" 
                                        Foreground="White"
                                        Click="BtnChangeRole_Click"
                                        Tag="{Binding}"/>

                                <Button Content="{Binding IsActive, StringFormat='{} {0}'}" 
                                        Width="110" 
                                        Height="38" 
                                        Margin="5"
                                        Background="{Binding IsActive, Converter={StaticResource BoolToBrushConverter}}"
                                        Foreground="White"
                                        Click="BtnToggleActive_Click"
                                        Tag="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>