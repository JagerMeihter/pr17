<Page x:Class="pr17.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель администратора"
      Background="#1E1E2F">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Панель администратора" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#E74C3C" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Управление пользователями системы" 
                       FontSize="14" 
                       Foreground="#AAAAAA" 
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Список пользователей -->
        <ListView x:Name="lvUsers" 
                  Grid.Row="1"
                  Background="Transparent" 
                  BorderBrush="#34495E"
                  Foreground="White"
                  Margin="10">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2C3E50" 
                            CornerRadius="8" 
                            Padding="15" 
                            Margin="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" 
                                           FontSize="16" 
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding Login}" 
                                           Foreground="#3498DB"/>
                                <TextBlock Text="{Binding Phone}" 
                                           Foreground="#AAAAAA"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" 
                                       Text="{Binding Role}" 
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="20,0"
                                       Foreground="#F1C40F"/>

                            <!-- Кнопки управления -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Изменить роль" 
                                        Width="130" 
                                        Height="35" 
                                        Margin="5"
                                        Background="#3498DB" 
                                        Foreground="White"
                                        Click="BtnChangeRole_Click"
                                        Tag="{Binding}"/>

                                <Button Content="Заморозить" 
                                        Width="100" 
                                        Height="35" 
                                        Margin="5"
                                        Background="#E67E22" 
                                        Foreground="White"
                                        Click="BtnToggleActive_Click"
                                        Tag="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>