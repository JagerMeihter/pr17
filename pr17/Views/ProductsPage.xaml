<Page x:Class="pr17.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:pr17"
      Title="Магазин косметики"
      Background="#1E1E2F">

    <Page.Resources>
        <local:DiscountConverter x:Key="DiscountConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров и поиска -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBox x:Name="txtSearch" 
                     Width="300" 
                     Height="35" 
                     Margin="5"
                     Background="#2C3E50" 
                     Foreground="White"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearch_TextChanged"/>

            <Button Content="Поиск" 
                    Width="90" 
                    Height="35" 
                    Margin="5"
                    Background="#3498DB" 
                    Foreground="White"
                    Click="BtnSearch_Click"/>

            <Button Content="Корзина" 
                    Width="110" 
                    Height="35" 
                    Margin="20,5,5,5"
                    Background="#E67E22" 
                    Foreground="White"
                    Click="BtnCart_Click"/>
        </StackPanel>

        <!-- Сетка товаров -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="wrapPanelProducts" HorizontalAlignment="Left"/>
        </ScrollViewer>
    </Grid>
</Page>