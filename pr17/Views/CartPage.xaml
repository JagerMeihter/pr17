<Page x:Class="pr17.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Корзина"
      Background="#1E1E2F">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Корзина" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#3498DB" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Список товаров в корзине -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="stackCartItems"/>
        </ScrollViewer>

        <!-- Нижняя панель с итогом и кнопками -->
        <Border Grid.Row="2" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,20,0,0">
            <StackPanel>
                <TextBlock x:Name="txtTotal" 
                           Text="Итого: 0 ₽" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#2ECC71"
                           HorizontalAlignment="Right"
                           Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Очистить корзину" 
                            Width="160" 
                            Height="40" 
                            Margin="10"
                            Background="#E74C3C" 
                            Foreground="White"
                            Click="BtnClear_Click"/>

                    <Button Content="Оформить заказ" 
                            Width="180" 
                            Height="40" 
                            Margin="10"
                            Background="#27AE60" 
                            Foreground="White"
                            FontSize="15"
                            Click="BtnCheckout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>