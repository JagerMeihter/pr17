<Page x:Class="pr17.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная страница"
      Background="#1E1E2F">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">

            <!-- Логотип / Заголовок -->
            <TextBlock Text="КОСМИЧЕСКАЯ ЛОЖА" 
                       FontSize="42" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Салон красоты • Магазин косметики" 
                       FontSize="18" 
                       Foreground="#AAAAAA" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,60"/>

            <!-- Кнопки действий -->
            <Button Content="Войти в аккаунт" 
                    Height="55" 
                    Width="320" 
                    FontSize="18" 
                    Margin="0,15"
                    Background="#27AE60" 
                    Foreground="White"
                    Click="BtnLogin_Click"/>

            <Button Content="Перейти в магазин косметики" 
                    Height="55" 
                    Width="320" 
                    FontSize="18" 
                    Margin="0,15"
                    Background="#E67E22" 
                    Foreground="White"
                    Click="BtnShop_Click"/>

            <TextBlock Text="Добро пожаловать в мир совершенства" 
                       FontSize="14" 
                       Foreground="#777777" 
                       HorizontalAlignment="Center"
                       Margin="0,80,0,0"/>
        </StackPanel>
    </Grid>
</Page>