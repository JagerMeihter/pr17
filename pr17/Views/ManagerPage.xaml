<Page x:Class="pr17.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель менеджера"
      Background="#1E1E2F">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Панель менеджера" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#3498DB" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Background="Transparent" BorderBrush="#34495E">

            <!-- Вкладка 1: Записи -->
            <TabItem Header="Записи">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Content="Создать новую запись" 
                            Width="200" 
                            Height="40" 
                            Margin="10"
                            Background="#27AE60" 
                            Foreground="White"
                            HorizontalAlignment="Left"
                            Click="BtnNewAppointment_Click"/>

                    <ListView x:Name="lvAppointments" 
                              Grid.Row="1"
                              Background="Transparent" 
                              BorderBrush="#34495E"
                              Foreground="White"
                              Margin="10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2C3E50" CornerRadius="6" Padding="12" Margin="5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Client.FullName}" FontWeight="Bold" FontSize="15"/>
                                        <TextBlock Text="{Binding Master.FullName}" Foreground="#3498DB"/>
                                        <TextBlock Text="{Binding ServiceType.Name}"/>
                                        <TextBlock Text="{Binding DateTime, StringFormat='dd.MM.yyyy HH:mm'}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Заказы -->
            <TabItem Header="Заказы">
                <ListView x:Name="lvOrders" 
                          Background="Transparent" 
                          BorderBrush="#34495E"
                          Foreground="White"
                          Margin="10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2C3E50" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="{Binding Client.FullName}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding OrderDate, StringFormat='Заказ от dd.MM.yyyy'}"/>
                                    <Button Content="Выдать заказ" 
                                            Width="140" 
                                            Height="35" 
                                            Background="#2ECC71" 
                                            Foreground="White"
                                            HorizontalAlignment="Right"
                                            Click="BtnDeliverOrder_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabItem>

            <!-- Вкладка 3: Товары -->
            <TabItem Header="Товары">
                <TextBlock Text="Управление товарами (в разработке)" 
                           FontSize="16" 
                           Foreground="#AAAAAA" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </TabItem>

            <!-- Вкладка 4: Справочники -->
            <TabItem Header="Справочники">
                <TextBlock Text="Управление типами услуг, производителями и категориями (в разработке)" 
                           FontSize="16" 
                           Foreground="#AAAAAA" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </TabItem>

        </TabControl>
    </Grid>
</Page>