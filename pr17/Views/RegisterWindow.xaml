<Window x:Class="pr17.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация клиента" 
        Height="880" 
        Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2F"
        ResizeMode="NoResize">

    <Grid Margin="40,40,40,40">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="Регистрация нового клиента" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="#3498DB" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- ФИО -->
            <TextBlock Text="ФИО *" 
                       Foreground="#E0E0E0" 
                       FontSize="14" 
                       Margin="0,0,0,8"/>
            <TextBox x:Name="txtFullName" 
                     Height="45" 
                     Background="#2C3E50" 
                     Foreground="White" 
                     FontSize="15" 
                     Padding="12,0"/>

            <!-- Телефон -->
            <TextBlock Text="Телефон" 
                       Foreground="#E0E0E0" 
                       FontSize="14" 
                       Margin="0,22,0,8"/>
            <TextBox x:Name="txtPhone" 
                     Height="45" 
                     Background="#2C3E50" 
                     Foreground="White" 
                     FontSize="15" 
                     Padding="12,0"/>

            <!-- Логин -->
            <TextBlock Text="Логин *" 
                       Foreground="#E0E0E0" 
                       FontSize="14" 
                       Margin="0,22,0,8"/>
            <TextBox x:Name="txtLogin" 
                     Height="45" 
                     Background="#2C3E50" 
                     Foreground="White" 
                     FontSize="15" 
                     Padding="12,0"/>

            <!-- Пароль -->
            <TextBlock Text="Пароль *" 
                       Foreground="#E0E0E0" 
                       FontSize="14" 
                       Margin="0,22,0,8"/>
            <PasswordBox x:Name="txtPassword" 
                         Height="45" 
                         Background="#2C3E50" 
                         Foreground="White" 
                         FontSize="15" 
                         Padding="12,0"/>

            <!-- Кнопки -->
            <Button Content="Зарегистрироваться и войти" 
                    Height="52" 
                    Margin="0,45,0,15" 
                    Background="#27AE60" 
                    Foreground="White"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Click="BtnRegister_Click"/>

            <Button Content="Отмена" 
                    Height="45" 
                    Background="#E74C3C" 
                    Foreground="White"
                    FontSize="15"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>